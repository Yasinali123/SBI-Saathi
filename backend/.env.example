# SBI Saathi Backend — Environment Variables

# MongoDB
MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sbi_saathi?retryWrites=true&w=majority
MONGODB_DB_NAME=sbi_saathi

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-256-bit-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# App
APP_ENV=development
DEBUG=true
